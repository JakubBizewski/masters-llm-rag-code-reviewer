# API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# GitHub Configuration
# Option 1: Personal Access Token (deprecated for production)
GITHUB_TOKEN=ghp_...

# Option 2: GitHub App (recommended)
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY_PATH=./github-app-private-key.pem
GITHUB_APP_INSTALLATION_ID=12345678  # Optional, can be auto-detected

GITHUB_WEBHOOK_SECRET=your-webhook-secret

# GitLab Configuration
GITLAB_TOKEN=glpat-...
GITLAB_WEBHOOK_SECRET=your-webhook-secret

# Application Settings
ACR_ENV=development
ACR_LOG_LEVEL=INFO
ACR_API_HOST=0.0.0.0
ACR_API_PORT=8000

# Database (optional - for review history)
DATABASE_URL=sqlite:///./acr.db

# RAG Configuration
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_TOP_K=5
RAG_FAISS_INDEX_PATH=./faiss_index

# LLM Configuration
# Provider: openai or anthropic
LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o
# For Anthropic: claude-3-5-sonnet-20241022, claude-3-opus-20240229, claude-3-5-haiku-20241022
DEFAULT_LLM_TEMPERATURE=0.3
DEFAULT_LLM_MAX_TOKENS=2000
